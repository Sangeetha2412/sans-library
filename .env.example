# Flask Configuration
FLASK_ENV=development
SECRET_KEY=generate-a-random-string-here-at-least-32-chars

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:yourpassword@db.xxxx.supabase.co:5432/postgres?sslmode=require

# Admin Credentials (DO NOT HARDCODE IN SOURCE)
ADMIN_USERNAME=admin
ADMIN_EMAIL=owner@sanslib.com
ADMIN_PASSWORD_HASH=pbkdf2:sha256:...generated-by-werkzeug...

# Admin Secret Key (URL protection)
ADMIN_SECRET_KEY=your-secret-key-change-in-render

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional: Redis for rate limiting in production
# REDIS_URL=redis://...
